---
import { getLangFromUrl, getDateLocale, type Lang } from '@/i18n/utils'

export interface Props {
	date: Date
	lang?: Lang
}

const { date, lang: propLang } = Astro.props
const lang = propLang || getLangFromUrl(Astro.url)
const dateLocale = getDateLocale(lang)
---

<time class='text-sm font-bold text-opacity-60' datetime={date.toISOString()}>
	{
		date.toLocaleDateString(dateLocale, {
			year: 'numeric',
			month: 'short',
			day: 'numeric'
		})
	}
</time>
