---
import { cn, sluglify } from '@/utils'
import { getLangFromUrl, useTranslations, getLocalePath, type Lang } from '@/i18n/utils'

interface Props {
	name?: string
	activeCategory?: string
	lang?: Lang
}

const { name, activeCategory, lang: propLang } = Astro.props
const lang = propLang || getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const displayName = name || t('category.viewAll')
const currentPath = Astro.url.pathname
const unsluglifyNameCategory = name ? sluglify(name.toLowerCase()) : ''

const isActive =
	activeCategory?.toLocaleLowerCase() === unsluglifyNameCategory ||
	(currentPath === '/' && !name) ||
	(currentPath === '/zh/' && !name) ||
	(currentPath === '/zh' && !name)
---

<a
	href={!name
		? getLocalePath(lang, '/')
		: getLocalePath(lang, sluglify(`/category/${unsluglifyNameCategory}/1`))}
	class={cn(
		`text-gray-600 dark:text-gray-300  pb-2.5 first-letter:uppercase font-medium hover:text-gray-800 border-b-2 border-opacity-0 dark:border-opacity-0 border-black dark:border-white dark:hover:border-white hover:border-opacity-100 transition-colors duration-150 ease-linear  `,
		isActive &&
			`border-black border-b-2 text-black z-10  dark:border-white dark:text-white dark:border-opacity-100 border-opacity-100`
	)}
>
	{displayName}
</a>
