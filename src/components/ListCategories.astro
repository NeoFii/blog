---
import { getCategories } from '@/utils'
import Category from '@/components/Category'
import { getLangFromUrl, type Lang } from '@/i18n/utils'

interface Props {
	activeCategory?: string
	lang?: Lang
}

const { activeCategory, lang: propLang } = Astro.props
const lang = propLang || getLangFromUrl(Astro.url)
const categories = await getCategories()
---

<div class='relative flex flex-wrap min-w-full gap-5'>
	<Category lang={lang} />
	{
		categories.map((category: string) => (
			<Category name={category} activeCategory={activeCategory} lang={lang} />
		))
	}

	<div class='hidden sm:block absolute w-full bottom-0 border-b-2 -z-40 dark:border-gray-600'></div>
</div>
